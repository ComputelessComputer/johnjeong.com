{
  "name": "johnjeong",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "rm -rf .vercel/output && git submodule update --init --recursive --remote && astro dev",
    "normalize:content-images": "bun run scripts/normalize-content-image-paths.ts",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "rm -rf .vercel/output && astro check",
    "fmt": "bunx prettier . --write --ignore-path .prettierignore",
    "fmt:check": "bunx prettier . --check --ignore-path .prettierignore",
    "check": "bun run lint && bun run fmt:check"
  },
  "dependencies": {
    "@astrojs/vercel": "^9.0.2",
    "@vercel/og": "^0.11.1",
    "astro": "^5.16.6",
    "exifreader": "^4.33.1",
    "lz-string": "^1.5.0",
    "react": "^19.2.4",
    "remark-unwrap-images": "^5.0.0",
    "resend": "^6.6.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@types/react": "^19.2.14",
    "prettier": "3.7.4",
    "typescript": "^5.9.3"
  }
}
