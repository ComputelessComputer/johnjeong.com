---
interface Props {
  currentPage?: string;
  title?: string;
  subtitle?: string;
  showGoBack?: boolean;
  titleVideoSrc?: string;
  titleVideoType?: string;
  titleVideoPoster?: string;
}

const {
  currentPage,
  title = "John Jeong",
  subtitle = 'Co-founder & Co-CEO at <a href="https://char.com" target="_blank" rel="noopener" class="hyprnote-link hyprnote-logo-link"><img src="/char.svg" alt="Char" class="char-logo" width="332" height="100" /></a>',
  showGoBack = false,
  titleVideoSrc,
  titleVideoType,
  titleVideoPoster,
} = Astro.props;

const shouldAnimateTitle = !Astro.slots.has("title-extra") && currentPage === "home" && title === "John Jeong";
const shouldShowTitleVideo = shouldAnimateTitle && Boolean(titleVideoSrc);

const navItems = [
  { href: "/", label: "About", key: "home" },
  { href: "/essays/en", label: "Essays", key: "essays" },
  { href: "/inspirations", label: "Inspirations", key: "inspirations" },
  { href: "/lessons", label: "Lessons", key: "lessons" },
  { href: "/gallery", label: "Gallery", key: "gallery" },
];
---

<header>
  <h1>
    {currentPage ? (
      Astro.slots.has('title-extra') ? (
        <slot name="title-extra" />
      ) : shouldAnimateTitle ? (
        <span
          class:list={["signature-wordmark", { "has-video": shouldShowTitleVideo }]}
          data-signature-video={shouldShowTitleVideo ? "" : undefined}
        >
          <span class="signature-wordmark-fill">{title}</span>
          <span class="signature-wordmark-stroke" aria-hidden="true">{title}</span>
          {shouldShowTitleVideo && (
            <video
              class="signature-wordmark-video"
              aria-hidden="true"
              autoplay
              muted
              playsinline
              preload="auto"
              poster={titleVideoPoster}
            >
              <source src={titleVideoSrc} type={titleVideoType} />
            </video>
          )}
        </span>
      ) : (
        title
      )
    ) : (
      <a href="/">
        {shouldAnimateTitle ? (
          <span
            class:list={["signature-wordmark", { "has-video": shouldShowTitleVideo }]}
            data-signature-video={shouldShowTitleVideo ? "" : undefined}
          >
            <span class="signature-wordmark-fill">{title}</span>
            <span class="signature-wordmark-stroke" aria-hidden="true">{title}</span>
            {shouldShowTitleVideo && (
              <video
                class="signature-wordmark-video"
                aria-hidden="true"
                autoplay
                muted
                playsinline
                preload="auto"
                poster={titleVideoPoster}
              >
                <source src={titleVideoSrc} type={titleVideoType} />
              </video>
            )}
          </span>
        ) : (
          title
        )}
      </a>
    )}
  </h1>
  {subtitle && (
    <p class="subtitle">
      <span class="subtitle-text" set:html={subtitle} />
    </p>
  )}
</header>

<div class="nav-container">
  <nav class:list={["main-nav", { "has-go-back": showGoBack }]}>
    {navItems.map((item) => (
      <div class="nav-item">
        <a href={item.href} class:list={[{ active: currentPage === item.key }]}>{item.label}</a>
        {showGoBack && currentPage === item.key && (
          <span class="go-back">Go back?</span>
        )}
      </div>
    ))}
  </nav>
</div>

<style is:global>
  header {
    margin-bottom: 1rem;
  }

  header h1 {
    margin-top: 0;
  }
  header h1 a {
    text-decoration: none;
  }
  .signature-wordmark {
    --signature-bleed-x: 0.16em;
    --signature-bleed-top: 0.08em;
    --signature-bleed-bottom: 0.14em;
    position: relative;
    display: inline-grid;
    justify-items: start;
    align-items: start;
    overflow: visible;
    line-height: 1;
    white-space: nowrap;
    vertical-align: top;
  }
  .signature-wordmark-fill,
  .signature-wordmark-stroke,
  .signature-wordmark-video {
    grid-area: 1 / 1;
    font-synthesis: none;
  }
  .signature-wordmark-fill,
  .signature-wordmark-stroke {
    display: block;
  }
  .signature-wordmark-fill {
    opacity: 0;
    animation: signature-fill-reveal 0.18s ease-out 1.42s forwards;
  }
  .signature-wordmark-stroke {
    position: absolute;
    top: calc(var(--signature-bleed-top) * -1);
    right: calc(var(--signature-bleed-x) * -1);
    bottom: calc(var(--signature-bleed-bottom) * -1);
    left: calc(var(--signature-bleed-x) * -1);
    padding:
      var(--signature-bleed-top)
      var(--signature-bleed-x)
      var(--signature-bleed-bottom);
    color: inherit;
    -webkit-text-fill-color: currentColor;
    clip-path: inset(0 100% 0 0);
    pointer-events: none;
    animation: signature-stroke-pass 1.55s cubic-bezier(0.2, 0.8, 0.2, 1) 0.12s forwards;
  }
  .signature-wordmark-video {
    position: absolute;
    top: calc(var(--signature-bleed-top) * -1);
    right: calc(var(--signature-bleed-x) * -1);
    bottom: calc(var(--signature-bleed-bottom) * -1);
    left: calc(var(--signature-bleed-x) * -1);
    display: block;
    width: auto;
    height: auto;
    max-width: none;
    object-fit: contain;
    object-position: top left;
    opacity: 1;
    pointer-events: none;
    transition: opacity 0.14s ease;
    will-change: opacity;
  }
  .signature-wordmark.has-video .signature-wordmark-fill {
    opacity: 1;
    animation: none;
  }
  .signature-wordmark.has-video .signature-wordmark-stroke {
    display: none;
  }
  .signature-wordmark.has-video .signature-wordmark-video.is-hidden {
    display: none;
  }
  .subtitle {
    color: #666;
    overflow-wrap: anywhere;
    text-wrap: pretty;
  }
  .subtitle .subtitle-text {
    display: block;
  }
  .hyprnote-link {
    font-family: var(--font-serif);
    text-decoration: none;
  }
  .hyprnote-logo-link {
    display: inline-block;
    line-height: 0;
    vertical-align: -0.08em;
  }
  .char-logo {
    display: block;
    width: auto;
    height: 0.84em;
  }
  .hyprnote-link:hover {
    text-decoration: underline;
    text-decoration-style: dotted;
  }
  .nav-container {
    position: relative;
    margin-bottom: 0.5rem;
  }
  .nav-container::before,
  .nav-container::after {
    content: '';
    position: absolute;
    top: 0;
    height: 1.5rem;
    width: 2rem;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s ease;
    z-index: 1;
  }
  .nav-container::before {
    left: 0;
    background: linear-gradient(to right, #fff 0%, transparent 100%);
  }
  .nav-container::after {
    right: 0;
    background: linear-gradient(to left, #fff 0%, transparent 100%);
  }
  .nav-container.scroll-left::before {
    opacity: 1;
  }
  .nav-container.scroll-right::after {
    opacity: 1;
  }
  .main-nav {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    padding-bottom: 1.5rem;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .main-nav::-webkit-scrollbar {
    display: none;
  }
  .nav-item a {
    text-decoration: none;
    color: #666;
    padding-bottom: 0.25rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }
  .nav-item a:hover {
    color: #1a1a1a;
  }
  .nav-item a.active {
    color: #1a1a1a !important;
    border-bottom: 2px solid #1a1a1a !important;
  }
  .nav-item {
    position: relative;
    flex-shrink: 0;
  }
  .go-back {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-sans);
    font-size: 0.65rem;
    color: #666;
    opacity: 0.5;
    white-space: nowrap;
    margin-top: 0.25rem;
  }
  @keyframes signature-stroke-pass {
    0% {
      clip-path: inset(0 100% 0 0);
      opacity: 1;
    }
    88% {
      clip-path: inset(0 0 0 0);
      opacity: 1;
    }
    100% {
      clip-path: inset(0 0 0 0);
      opacity: 0;
    }
  }
  @keyframes signature-fill-reveal {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .signature-wordmark-fill {
      animation: none;
      opacity: 1;
    }
    .signature-wordmark-stroke {
      animation: none;
      opacity: 0;
    }
    .signature-wordmark-video {
      display: none;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const signatureWordmarks = document.querySelectorAll<HTMLElement>('[data-signature-video]');

    for (const wordmark of signatureWordmarks) {
      const video = wordmark.querySelector<HTMLVideoElement>('.signature-wordmark-video');

      if (!video) {
        continue;
      }

      video.addEventListener('ended', () => {
        video.pause();

        if (video.duration > 0) {
          video.currentTime = Math.max(video.duration - 0.001, 0);
        }
      }, { once: true });

      video.addEventListener('error', () => {
        video.classList.add('is-hidden');
      }, { once: true });

      video.addEventListener('stalled', () => {
        video.classList.add('is-hidden');
      }, { once: true });
    }

    // Nav scroll fade indicators
    const navContainer = document.querySelector('.nav-container');
    const nav = document.querySelector('.main-nav');

    if (navContainer && nav) {
      const updateScrollIndicators = () => {
        const scrollLeft = nav.scrollLeft;
        const maxScroll = nav.scrollWidth - nav.clientWidth;

        navContainer.classList.toggle('scroll-left', scrollLeft > 2);
        navContainer.classList.toggle('scroll-right', scrollLeft < maxScroll - 2);
      };

      nav.addEventListener('scroll', updateScrollIndicators);
      window.addEventListener('resize', updateScrollIndicators);
      updateScrollIndicators();
    }
  });
</script>
