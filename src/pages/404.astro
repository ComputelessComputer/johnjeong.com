---
import Header from "../components/Header.astro";
import Base from "../layouts/Base.astro";

Astro.response.status = 404;
---

<Base
  title="Page not found"
  description="The page you were looking for could not be found."
  canonicalPath="/404"
  ogEyebrow="404"
>
  <Header
    currentPage="not-found"
    title="Page not found"
    subtitle="The page you were looking for does not exist."
  />

  <main class="not-found" aria-labelledby="not-found-title">
    <p class="code" aria-hidden="true">404</p>
    <h2 id="not-found-title">This page went missing.</h2>
    <p>
      It may have moved, or the link might be wrong. The best place to restart
      is the home page.
    </p>
    <a class="home-link" href="/">Go home</a>
  </main>
</Base>

<style>
  .not-found {
    margin-top: 2rem;
  }

  .code {
    margin-bottom: 0.4rem;
    color: #777;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
  }

  h2 {
    margin-top: 0;
    margin-bottom: 0.75rem;
  }

  .home-link {
    display: inline-block;
    margin-top: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
</style>
