---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Giscus from "../../components/Giscus.astro";
import {
  formatJournalDate,
  getJournalRelativeDate,
  getJournalTimeZone,
} from "../../utils/journal-date";

export async function getStaticPaths() {
  const journals = await getCollection("journals");
  return journals.map((journal) => ({
    params: { id: journal.id },
    props: { journal },
  }));
}

const { journal } = Astro.props;
const { Content } = await render(journal);

const dateStr = journal.id.replace(/_/g, "-");
const timeZone = getJournalTimeZone(journal.data.city);
const relativeDate = getJournalRelativeDate(dateStr, timeZone);
const fullDate = formatJournalDate(dateStr);
---

<Base title={`Journal: ${dateStr}`}>
  <Header currentPage="journals" showGoBack={true} title={relativeDate} subtitle={fullDate} />

  <article>
    <div class="prose">
      <Content />
    </div>
  </article>

  <Giscus category="journals" />
</Base>
