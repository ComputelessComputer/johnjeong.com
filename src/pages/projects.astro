---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";

const projects = [
  {
    name: "Char",
    href: "https://char.com",
    description: "The core thing I work on: software that helps founders stay on top of their day.",
  },
  {
    name: "Philo",
    href: "https://philo.so",
    description: "A lightweight daily notes tool that carries unfinished work forward.",
  },
  {
    name: "Openbird",
    href: "https://openbird.vercel.app",
    description: "An exploration of software that can understand what has already been done.",
  },
  {
    name: "aipm",
    href: "https://github.com/ComputelessComputer/aipm",
    description: "A small AI task manager I built for myself.",
  },
  {
    name: "slate",
    href: "https://github.com/ComputelessComputer/slate",
    description: "A small tool that syncs my reMarkable notes into Obsidian.",
  },
  {
    name: "part of my brain",
    href: "https://github.com/ComputelessComputer/part-of-my-brain",
    description: "The public slice of my Obsidian vault that powers the writing on this site.",
  },
  {
    name: "modernfaber",
  },
];
---

<Base
  title="Projects"
  description="Projects I've built and worked on."
  ogEyebrow="Projects"
>
  <Header currentPage="projects" title="Projects" subtitle="Projects I've built and worked on." />

  <section aria-labelledby="projects-title">
    <h2 id="projects-title">Projects</h2>
    <ul class="project-flow-list">
      {projects.map((item) => (
        <li>
          {item.href ? (
            <a href={item.href} target="_blank" rel="noopener">{item.name}</a>
          ) : (
            <span class="project-name">{item.name}</span>
          )}
          {item.description && <span>: {item.description}</span>}
        </li>
      ))}
    </ul>
  </section>
</Base>

<style>
  h2 {
    margin-top: 0;
    margin-bottom: 0.75rem;
  }

  .project-flow-list {
    list-style: none;
    padding-left: 0;
    margin-bottom: 0;
    color: #555;
  }

  .project-flow-list li {
    margin-bottom: 0.65rem;
  }

  .project-flow-list li:last-child {
    margin-bottom: 0;
  }

  .project-flow-list a {
    font-weight: 600;
    text-decoration: none;
    color: #1a1a1a;
  }

  .project-flow-list a:hover {
    text-decoration: underline;
  }
</style>
