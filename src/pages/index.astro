---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";

const interests = [
  "Building software that feels simple, clear, and durable.",
  "Writing about taste, craftsmanship, and the process of making useful things.",
  "Collecting lessons, references, and ideas worth returning to.",
  "Photography and keeping a record of what I notice.",
];
---

<Base
  title="John Jeong"
  description="Co-founder & Co-CEO at Char. Notes on software, work, and things I care about."
  ogEyebrow="About"
  hideFooter={true}
>
  <Header
    currentPage="home"
    subtitle='Co-founder & Co-CEO at <a href="https://char.com" target="_blank" rel="noopener" class="hyprnote-link">Char</a>.'
  />

  <section class="intro">
    <p>I'm John Jeong.</p>
    <p>
      I work on <a href="https://char.com" target="_blank" rel="noopener">Char</a>.
      I like building software that is simple, legible, and built to last.
    </p>
    <p>
      This site is where I keep essays, lessons, inspirations, and a few photos.
    </p>
  </section>

  <section aria-labelledby="interests-title">
    <h2 id="interests-title">Things I'm working on and interested in</h2>
    <ul class="interest-list">
      {interests.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </section>

  <section class="elsewhere" aria-labelledby="elsewhere-title">
    <h2 id="elsewhere-title">Elsewhere</h2>
    <div class="social">
      <a href="https://www.linkedin.com/in/johntopia/" target="_blank" rel="noopener" aria-label="LinkedIn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
        </svg>
      </a>
      <a href="https://x.com/computeless" target="_blank" rel="noopener" aria-label="X">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
        </svg>
      </a>
      <a href="https://github.com/ComputelessComputer" target="_blank" rel="noopener" aria-label="GitHub">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
        </svg>
      </a>
    </div>
    <p><a href="/cal">Calendar</a>.</p>
    <p>
      This site is open source.
      <a href="/essays/building-my-new-website">Here's how I built it</a>.
    </p>
  </section>
</Base>

<style>
  section {
    margin-bottom: 2rem;
  }

  .intro {
    margin-top: 1.5rem;
  }

  .intro p:last-child,
  .elsewhere p:last-child,
  .interest-list {
    margin-bottom: 0;
  }

  h2 {
    margin-top: 0;
    margin-bottom: 0.75rem;
  }

  .interest-list {
    padding-left: 1.1rem;
  }

  .interest-list li {
    margin-bottom: 0.6rem;
  }

  .interest-list li:last-child {
    margin-bottom: 0;
  }

  .social {
    display: flex;
    gap: 1rem;
    margin-bottom: 0.9rem;
    align-items: center;
  }

  .social a {
    color: #666;
    display: flex;
    align-items: center;
    transition: color 0.2s;
  }

  .social a:hover {
    color: #1a1a1a;
  }

  .elsewhere p {
    margin-bottom: 0.65rem;
  }
</style>
