---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";

const interests = [
  "Building software that feels simple, clear, and durable.",
  "Writing about taste, craftsmanship, and the process of making useful things.",
  "Collecting lessons, references, and ideas worth returning to.",
  "Photography and keeping a record of what I notice.",
];
---

<Base
  title="John Jeong"
  description="Co-founder & Co-CEO at Char. Notes on software, work, and things I care about."
  ogEyebrow="About"
  hideFooter={true}
>
  <Header
    currentPage="home"
    subtitle='Co-founder & Co-CEO at <a href="https://char.com" target="_blank" rel="noopener" class="hyprnote-link">Char</a>.'
  />

  <section class="intro">
    <p>I'm John Jeong.</p>
    <p>
      I work on <a href="https://char.com" target="_blank" rel="noopener">Char</a>.
      I like building software that is simple, legible, and built to last.
    </p>
    <p>
      This site is where I keep essays, lessons, inspirations, and a few photos.
    </p>
  </section>

  <section aria-labelledby="interests-title">
    <h2 id="interests-title">Things I'm working on and interested in</h2>
    <ul class="interest-list">
      {interests.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </section>

  <section class="elsewhere" aria-labelledby="elsewhere-title">
    <h2 id="elsewhere-title">Elsewhere</h2>
    <p>
      <a href="https://x.com/computeless" target="_blank" rel="noopener">X</a>,
      <a href="https://github.com/ComputelessComputer" target="_blank" rel="noopener">GitHub</a>,
      <a href="https://www.linkedin.com/in/johntopia/" target="_blank" rel="noopener">LinkedIn</a>,
      and <a href="/cal">calendar</a>.
    </p>
    <p>
      This site is open source.
      <a href="/essays/building-my-new-website">Here's how I built it</a>.
    </p>
  </section>
</Base>

<style>
  section {
    margin-bottom: 2rem;
  }

  .intro {
    margin-top: 1.5rem;
  }

  .intro p:last-child,
  .elsewhere p:last-child,
  .interest-list {
    margin-bottom: 0;
  }

  h2 {
    margin-top: 0;
    margin-bottom: 0.75rem;
  }

  .interest-list {
    padding-left: 1.1rem;
  }

  .interest-list li {
    margin-bottom: 0.6rem;
  }

  .interest-list li:last-child {
    margin-bottom: 0;
  }

  .elsewhere p {
    margin-bottom: 0.65rem;
  }
</style>
